{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hwLedger",
  "version": "0.0.1",
  "identifier": "dev.hwledger.tauri",
  "build": {
    "beforeDevCommand": "pnpm --filter hwledger-tauri dev",
    "beforeBuildCommand": "pnpm --filter hwledger-tauri build",
    "devUrl": "http://localhost:5178",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "hwLedger",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' ipc: http://ipc.localhost https://huggingface.co"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Plan, probe, and run LLMs on local hardware",
    "longDescription": "hwLedger: plan GPU memory footprints, probe hardware, manage fleets, and search Hugging Face — hybrid SwiftUI (mac) + Tauri (win/linux) clients share a Rust core.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "signCommand": null
    }
  },
  "plugins": {}
}
