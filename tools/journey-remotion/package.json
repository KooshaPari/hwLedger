{
  "name": "hwledger-journey-remotion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Remotion pipeline that enriches hwLedger CLI journey recordings with callouts, captions, keyframe annotations, and optional TTS.",
  "scripts": {
    "studio": "remotion studio src/index.tsx",
    "render": "remotion render src/index.tsx",
    "render:plan-deepseek": "remotion render src/index.tsx JourneyRich --props='{\"journeyId\":\"plan-deepseek\"}' --output out/plan-deepseek.rich.mp4",
    "annotate": "bun run src/annotate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.257",
    "@remotion/cli": "4.0.257",
    "@remotion/renderer": "4.0.257",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.257",
    "sharp": "0.33.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
