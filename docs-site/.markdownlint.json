{
  "line-length": {
    "line_length": 100,
    "heading_line_length": 100,
    "code_blocks": false,
    "code_lines": false,
    "tables": false,
    "headers": true
  },
  "no-trailing-spaces": true,
  "no-bare-urls": true,
  "no-multiple-blanks": {
    "maximum": 1
  },
  "no-hard-tabs": true,
  "list-indent": true,
  "ul-indent": {
    "indent": 2
  },
  "ul-start-left": true,
  "ordered-list-prefix": true,
  "no-trailing-punctuation": {
    "punctuation": ".,;:!"
  },
  "md003": {
    "style": "consistent"
  },
  "MD024": {
    "allow_different_nesting": true,
    "siblings_only": true
  },
  "no-inline-html": {
    "allowed_elements": ["component"]
  },
  "first-line-h1": true,
  "fenced-code-language": true,
  "heading-increment": true,
  "no-duplicate-heading": {
    "siblings_only": true
  }
}
