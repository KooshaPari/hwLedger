{
  "name": "hwledger-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:adrs": "bash scripts/sync-adrs.sh",
    "sync:journeys": "bash scripts/sync-journey-artefacts.sh",
    "sync:cli-journeys": "bash scripts/sync-cli-journeys.sh",
    "sync:streamlit-journeys": "bash scripts/sync-streamlit-journeys.sh",
    "sync:research": "bash scripts/sync-research.sh",
    "sync": "bash scripts/sync-adrs.sh && bash scripts/sync-cli-journeys.sh && bash scripts/sync-journey-artefacts.sh && bash scripts/sync-streamlit-journeys.sh && bash scripts/sync-research.sh",
    "dev": "bun run sync && vitepress dev .",
    "build": "bun run sync && vitepress build .",
    "preview": "vitepress preview .",
    "link-check": "linkinator .vitepress/dist --recurse --markdown",
    "lint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "markdownlint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\""
  },
  "dependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "linkinator": "^6.0.0",
    "markdown-it-mathjax3": "^4.3.2",
    "markdownlint-cli2": "^0.13.0",
    "mermaid": "^10.9.0",
    "vitepress": "1.6.4",
    "vitepress-plugin-mermaid": "^2.0.16"
  }
}
