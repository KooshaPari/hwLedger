/target
/Cargo.lock.bak
**/*.rs.bk

# Xcode / Swift
apps/macos/.build/
apps/macos/DerivedData/
apps/macos/*.xcworkspace/xcuserdata/
apps/macos/*.xcodeproj/xcuserdata/
apps/macos/*.xcodeproj/project.xcworkspace/xcuserdata/
apps/macos/xcframework/
*.xcframework
*.dSYM

# .NET / WinUI
apps/windows/bin/
apps/windows/obj/
apps/windows/*.user
apps/windows/AppPackages/

# Qt / Slint
apps/linux-qt/build/
apps/linux-slint/build/
*.autosave

# Python venv for MLX sidecar
sidecars/**/.venv/
sidecars/**/__pycache__/
sidecars/**/*.pyc
sidecars/**/.uv-cache/
sidecars/**/uv.lock.bak

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/
*.swp
.~*

# Attestation: log is committed (chain verification), private keys live
# under ~/.hwledger/attest-keys/ and never touch the repo. A stray .sk in
# a repo .hwledger/ folder would be a catastrophic secret leak.
.hwledger/*.sk
.hwledger/attest-keys/

# Secrets / local config
.env
.env.*
!.env.example
hwledger.local.toml

# Ledger data
ledger.db
ledger.db-*
*.sqlite
*.sqlite-journal
apps/macos/xcframework/

# Swift Package Manager build artefacts
apps/**/.build/
apps/**/.swiftpm/
apps/**/*.xcodeproj/
vendor/**/target
.claude/worktrees/
*.venv/

# hwledger-journey-render transient artifacts (built per-render)
apps/*/keyframes/*/manifest.rich.json
docs-site/public/*/keyframes/*/manifest.rich.json

# Worktree directories (org policy)
.worktrees/

# Worktree directories (org policy)
.worktrees/
